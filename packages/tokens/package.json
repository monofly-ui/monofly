{
  "name": "@monofly/tokens",
  "version": "0.0.2",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./tokens.css": "./tokens.css",
    "./theme.css": "./theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "tokens.css",
    "theme.css"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "script:tokens": "cd scripts && node --env-file=../../../.env app.mjs --skip-rest-api; cd -;",
    "script:tokens:rest": "cd scripts && node --env-file=../../../.env app.mjs; cd -;"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
